# ============================================
# FIREBASE ADMIN SDK CONFIGURATION
# ============================================
# These credentials are used for server-side operations with Firebase Admin SDK
# IMPORTANT: Never commit the actual .env file with real credentials to version control

# Firebase Project ID
# Find this in Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=your-project-id

# Firebase Service Account Email
# Find this in Firebase Console > Project Settings > Service Accounts
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Firebase Private Key
# Find this in Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ============================================
# FIREBASE CLIENT SDK CONFIGURATION (PUBLIC)
# ============================================
# These are public and safe to expose in the browser

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ============================================
# DON CANDIDO IA INTEGRATION
# ============================================
# URL base del backend Don Cándido (9001app-firebase).
# Sin slash al final. Ej: https://mi-app.vercel.app
NEXT_PUBLIC_DONC_SOLICITUDES_URL=https://your-doncandido-app.vercel.app

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Node environment (development, staging, production)
NODE_ENV=development

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application Name (shown in UI)
NEXT_PUBLIC_APP_NAME="Mi Aplicación"

# ============================================
# HOW TO GET FIREBASE CREDENTIALS
# ============================================
#
# 1. Go to Firebase Console: https://console.firebase.google.com/
# 2. Select your project (or create a new one)
# 3. Click on the gear icon next to "Project Overview"
# 4. Go to "Project Settings"
#
# For CLIENT SDK (NEXT_PUBLIC_*):
# 5. Scroll down to "Your apps" section
# 6. Click "Add app" > Web (</>)
# 7. Copy the firebaseConfig values
#
# For ADMIN SDK (FIREBASE_*):
# 8. Navigate to "Service Accounts" tab
# 9. Click "Generate New Private Key"
# 10. A JSON file will be downloaded with credentials
# 11. Copy values to this file
#
# ============================================
# SECURITY NOTES
# ============================================
#
# - NEVER commit .env.local with real credentials to Git
# - Add .env.local to .gitignore (already done)
# - Use different Firebase projects for dev/staging/prod
# - Rotate credentials regularly
# - Store production credentials in Vercel/hosting env vars
#

# ============================================
# 9001APP DEALER INTEGRATION
# ============================================

# URL base de 9001app para catalogo publico y solicitudes dealer.
# Sin slash al final. Ej: https://9001app-v8.vercel.app
NEXT_PUBLIC_9001APP_URL=https://your-9001app.vercel.app

# Valor de DEALER_PUBLIC_ORGANIZATION_ID para Agro Biciufa.
NEXT_PUBLIC_AGROBICIUFA_TENANT_KEY=your-agrobiciufa-tenant-key

# ── ElevenLabs Voice (TTS web + WhatsApp Agent) ──────────────
# API key de ElevenLabs: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...
# Voice ID del asistente (crear en ElevenLabs Voice Lab o usar el existente)
ELEVENLABS_VOICE_ID=kulszILr6ees0ArU8miO
# Agent ID del agente Agrobiciufa (obtenido en dashboard después de crear el agente)
# https://elevenlabs.io/app/conversational-ai
ELEVENLABS_AGENT_ID_AGROBICIUFA=agent_...
# Número WhatsApp Business de Agrobiciufa (formato E.164 sin +)
WHATSAPP_PHONE_NUMBER_ID_AGROBICIUFA=5491112345678
